{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "importOrder": ["^@shared/(.*)$", "^@client/(.*)$", "^@server/(.*)$", "^[./]"],
  "overrides": [
    {
      "files": ["*.json"],
      "options": { "singleQuote": false }
    }
  ]
}
